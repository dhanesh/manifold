{
  "$ref": "#/definitions/ManifoldStructure",
  "definitions": {
    "ManifoldStructure": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "schema_version": {
          "type": "number",
          "const": 3,
          "default": 3
        },
        "feature": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": [
            "INITIALIZED",
            "CONSTRAINED",
            "TENSIONED",
            "ANCHORED",
            "GENERATED",
            "VERIFIED"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "light",
            "full"
          ]
        },
        "domain": {
          "type": "string",
          "enum": [
            "software",
            "non-software"
          ]
        },
        "outcome_ref": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "template_version": {
          "type": "number"
        },
        "created": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        },
        "constraints": {
          "type": "object",
          "properties": {
            "business": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[BTUSO]\\d+$"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "invariant",
                      "goal",
                      "boundary"
                    ]
                  },
                  "verified_by": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string",
                          "enum": [
                            "file_exists",
                            "content_match",
                            "test_passes",
                            "metric_value",
                            "manual_review"
                          ]
                        },
                        "path": {
                          "type": "string"
                        },
                        "pattern": {
                          "type": "string"
                        },
                        "test_name": {
                          "type": "string"
                        },
                        "metric_name": {
                          "type": "string"
                        },
                        "threshold": {
                          "type": [
                            "string",
                            "number"
                          ]
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "VERIFIED",
                            "PENDING",
                            "FAILED",
                            "STALE"
                          ]
                        },
                        "satisfies": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "test_tier": {
                          "type": "string",
                          "enum": [
                            "unit",
                            "integration",
                            "e2e"
                          ]
                        },
                        "validation_criteria": {
                          "type": "string"
                        },
                        "file_hash": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "id",
                        "type"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "source": {
                    "type": "string",
                    "enum": [
                      "interview",
                      "pre-mortem",
                      "assumption"
                    ]
                  },
                  "challenger": {
                    "type": "string",
                    "enum": [
                      "regulation",
                      "stakeholder",
                      "technical-reality",
                      "assumption"
                    ]
                  },
                  "threshold": {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "enum": [
                          "deterministic",
                          "statistical"
                        ]
                      },
                      "ceiling": {
                        "type": "string"
                      },
                      "p99": {
                        "type": "string"
                      },
                      "p50": {
                        "type": "string"
                      },
                      "failure_rate": {
                        "type": "string"
                      },
                      "window": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "kind"
                    ],
                    "additionalProperties": true
                  },
                  "quality": {
                    "type": "object",
                    "properties": {
                      "specificity": {
                        "type": "number",
                        "minimum": 1,
                        "maximum": 3
                      },
                      "measurability": {
                        "type": "number",
                        "minimum": 1,
                        "maximum": 3
                      },
                      "testability": {
                        "type": "number",
                        "minimum": 1,
                        "maximum": 3
                      }
                    },
                    "required": [
                      "specificity",
                      "measurability",
                      "testability"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "id",
                  "type"
                ],
                "additionalProperties": false
              },
              "default": []
            },
            "technical": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items"
              },
              "default": []
            },
            "user_experience": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items"
              },
              "default": []
            },
            "security": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items"
              },
              "default": []
            },
            "operational": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items"
              },
              "default": []
            }
          },
          "additionalProperties": false
        },
        "tensions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^TN\\d+$"
              },
              "type": {
                "type": "string",
                "enum": [
                  "trade_off",
                  "resource_tension",
                  "hidden_dependency"
                ]
              },
              "between": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 2
              },
              "status": {
                "type": "string",
                "enum": [
                  "resolved",
                  "unresolved"
                ]
              },
              "validation_criteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "triz_principles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "propagation_effects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "constraint_id": {
                      "type": "string"
                    },
                    "effect": {
                      "type": "string",
                      "enum": [
                        "TIGHTENED",
                        "LOOSENED",
                        "VIOLATED"
                      ]
                    },
                    "note": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "constraint_id",
                    "effect"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "id",
              "type",
              "between",
              "status"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "tension_summary": {
          "type": "object",
          "properties": {
            "trade_offs": {
              "type": "number"
            },
            "resource_tensions": {
              "type": "number"
            },
            "hidden_dependencies": {
              "type": "number"
            },
            "total": {
              "type": "number"
            },
            "resolved": {
              "type": "number"
            },
            "unresolved": {
              "type": "number"
            }
          },
          "required": [
            "trade_offs",
            "resource_tensions",
            "hidden_dependencies",
            "total",
            "resolved",
            "unresolved"
          ],
          "additionalProperties": false
        },
        "anchors": {
          "type": "object",
          "properties": {
            "required_truths": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^RT-[\\d.]+$"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "SATISFIED",
                      "PARTIAL",
                      "NOT_SATISFIED",
                      "SPECIFICATION_READY"
                    ]
                  },
                  "maps_to": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "evidence": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items/properties/verified_by/items"
                    }
                  },
                  "depth": {
                    "type": "number"
                  },
                  "children": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/ManifoldStructure/properties/anchors/properties/required_truths/items"
                    }
                  }
                },
                "required": [
                  "id",
                  "status"
                ],
                "additionalProperties": false
              },
              "default": []
            },
            "recommended_option": {
              "type": "string"
            },
            "implementation_phases": {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "additionalProperties": {}
                  }
                ]
              }
            },
            "anchor_document": {
              "type": "string"
            },
            "binding_constraint": {
              "type": "object",
              "properties": {
                "required_truth_id": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                },
                "dependency_chain": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "required_truth_id"
              ],
              "additionalProperties": false
            },
            "tension_validation": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "tension_id": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "CONFIRMED",
                      "REOPENED"
                    ]
                  },
                  "by_option": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                },
                "required": [
                  "tension_id",
                  "status"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "iterations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "number": {
                "type": "number"
              },
              "phase": {
                "type": "string"
              },
              "timestamp": {
                "type": "string"
              },
              "result": {
                "type": "string"
              }
            },
            "required": [
              "number",
              "phase",
              "timestamp",
              "result"
            ],
            "additionalProperties": true
          }
        },
        "convergence": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "NOT_STARTED",
                "IN_PROGRESS",
                "CONVERGED"
              ]
            },
            "criteria": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "all_invariants_satisfied": {
                      "type": "boolean"
                    },
                    "all_required_truths_satisfied": {
                      "type": "boolean"
                    },
                    "no_blocking_gaps": {
                      "type": "boolean"
                    },
                    "all_integrations_complete": {
                      "type": "boolean"
                    },
                    "strict_verification_passed": {
                      "type": "boolean"
                    },
                    "verification_passed": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                {
                  "type": "string"
                }
              ]
            },
            "iterations_to_convergence": {
              "type": "number"
            },
            "timestamp": {
              "type": "string"
            },
            "progress": {
              "type": "string"
            },
            "converged_at": {
              "type": "string"
            }
          },
          "required": [
            "status"
          ],
          "additionalProperties": false
        },
        "generation": {
          "type": "object",
          "properties": {
            "option": {
              "type": "string"
            },
            "timestamp": {
              "type": "string"
            },
            "iteration": {
              "type": "number"
            },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "satisfies": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "status": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "file_hash": {
                    "type": "string"
                  },
                  "artifact_class": {
                    "type": "string",
                    "enum": [
                      "substantive",
                      "structural"
                    ]
                  }
                },
                "required": [
                  "path",
                  "type",
                  "status"
                ],
                "additionalProperties": false
              }
            },
            "coverage": {
              "type": "object",
              "properties": {
                "constraints_addressed": {
                  "type": "number"
                },
                "constraints_total": {
                  "type": "number"
                },
                "required_truths_addressed": {
                  "type": "number"
                },
                "required_truths_total": {
                  "type": "number"
                },
                "percentage": {
                  "type": "number"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        },
        "reversibility_log": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action_step": {
                "type": "number"
              },
              "description": {
                "type": "string"
              },
              "reversibility": {
                "type": "string",
                "enum": [
                  "TWO_WAY",
                  "REVERSIBLE_WITH_COST",
                  "ONE_WAY"
                ]
              },
              "one_way_consequence": {
                "type": "string"
              }
            },
            "required": [
              "action_step",
              "description",
              "reversibility"
            ],
            "additionalProperties": false
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items/properties/verified_by/items"
          }
        },
        "constraint_graph": {
          "type": "object",
          "properties": {
            "version": {
              "type": "number"
            },
            "feature": {
              "type": "string"
            },
            "generated_at": {
              "type": "string"
            },
            "nodes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "constraint",
                      "tension",
                      "required_truth",
                      "artifact"
                    ]
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "UNKNOWN",
                      "REQUIRED",
                      "SATISFIED",
                      "BLOCKED",
                      "CONFLICTED"
                    ]
                  },
                  "depends_on": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "blocks": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "conflicts_with": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "critical_path": {
                    "type": "boolean"
                  },
                  "wave_number": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              }
            },
            "edges": {
              "type": "object",
              "properties": {
                "dependencies": {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 2
                      },
                      {
                        "type": "object",
                        "additionalProperties": {}
                      }
                    ]
                  }
                },
                "conflicts": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/ManifoldStructure/properties/constraint_graph/properties/edges/properties/dependencies/items"
                  }
                },
                "satisfies": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/ManifoldStructure/properties/constraint_graph/properties/edges/properties/dependencies/items"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "suggested_constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "enum": [
                  "business",
                  "technical",
                  "user_experience",
                  "security",
                  "operational"
                ]
              },
              "type": {
                "$ref": "#/definitions/ManifoldStructure/properties/constraints/properties/business/items/properties/type"
              },
              "source_constraint": {
                "type": "string"
              },
              "auto_generated": {
                "type": "boolean",
                "const": true
              },
              "promoted": {
                "type": "boolean",
                "default": false
              }
            },
            "required": [
              "id",
              "category",
              "type",
              "source_constraint",
              "auto_generated"
            ],
            "additionalProperties": false
          }
        },
        "gap_checklist_compliance": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "gap": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "COMPLETED",
                  "SKIPPED"
                ]
              },
              "skip_reason": {
                "type": "string"
              }
            },
            "required": [
              "gap",
              "status"
            ],
            "additionalProperties": false
          }
        },
        "draft_required_truths": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "seed_from": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "draft_statement": {
                "type": "string"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              }
            },
            "required": [
              "id",
              "seed_from",
              "draft_statement",
              "confidence"
            ],
            "additionalProperties": false
          }
        },
        "blocking_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "blocker": {
                "type": "string"
              },
              "blocked": {
                "type": "string"
              },
              "tension_id": {
                "type": "string"
              }
            },
            "required": [
              "blocker",
              "blocked",
              "tension_id"
            ],
            "additionalProperties": false
          }
        },
        "quick_summary": {
          "type": "object",
          "properties": {
            "started": {
              "type": "string"
            },
            "completed": {
              "type": "string"
            },
            "files_changed": {
              "type": "number"
            },
            "tests_added": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "feature",
        "phase"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}